{
  "name": "agentlock-typescript",
  "version": "0.1.0",
  "description": "Lightweight TypeScript SDK for emitting AgentLock-compatible traces from Node.js and TypeScript agents.",
  "license": "MIT",
  "author": "AgentLock",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm typecheck && tsup src/index.ts --format esm,cjs --dts --clean",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "agentlock",
    "ai",
    "tracing",
    "typescript",
    "nodejs",
    "observability"
  ],
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
